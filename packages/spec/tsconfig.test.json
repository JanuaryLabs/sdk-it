{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "baseUrl": ".",
    "rootDir": "src",
    "outDir": "dist",
    "tsBuildInfoFile": "dist/tsconfig.test.tsbuildinfo",
    "emitDeclarationOnly": false,
    "noEmit": true,
    "forceConsistentCasingInFileNames": true,
    "types": ["node"]
  },
  "include": ["src/**/*.test.ts"],
  "references": [
    {
      "path": "./tsconfig.lib.json"
    }
  ]
}
